---
import Base from '../Base.astro';
import NotFoundText from '../components/NotFoundText';
import SVGIcon from '../components/SVGIcon';
---

<Base title="404" width="small">
	<div class="contentBox">
		<div class="sideBySide">
			<div class="message">
				<h1>404</h1>
				<h2>Not Found</h2>
			</div>
			<div class="doodle">
				<img src="/doodle_404.png" />
				<span><NotFoundText client:load /></span>
			</div>
		</div>
		<div class="returnWrapper">
			<a href="/" class="linkButton">
				<SVGIcon src="/icons/chevron-left.svg" />
				return to home page
			</a>
		</div>
	</div>
</Base>

<style lang="scss">
	.sideBySide {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 4rem;
		box-sizing: border-box;
		padding: 3rem;
	}

	.message {
		display: flex;
		flex-direction: column;
		align-items: center;

		h1 {
			font-size: 8rem;
			font-weight: normal;
			margin: 0;
			margin-top: -1rem;
		}

		h2 {
			margin: 0;
			margin-top: -2rem;
			font-size: 1.5rem;
			display: flex;
			align-items: center;
		}
	}

	.doodle {
		display: flex;
		flex-direction: column;
		align-items: center;

		// TODO: this doesnt work well in dark mode.
		img {
			width: 6rem;
			mix-blend-mode: multiply;
			margin-bottom: 1rem;
		}

		span {
			max-width: 14rem;
			text-align: center;
			font-style: italic;
			opacity: 0.5;
		}
	}

	.returnWrapper {
		display: flex;
		align-items: center;
		justify-content: center;
		margin-top: calc(var(--content-gap-medium) * -1);
		margin-bottom: var(--content-gap-medium);

		a {
			background-color: var(--trim);
      color: var(--box-bg);

      &:is(:hover, :focus-visible) {
        background-color: var(--trim-hover);
      }
		}
	}
</style>